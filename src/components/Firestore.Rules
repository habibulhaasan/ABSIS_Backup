rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role','') == 'superadmin';
    }

    // Single get() — reuse result for all checks on same member doc
    function memberData(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data;
    }

    function memberExists(orgId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function isOrgAdmin(orgId) {
      return memberExists(orgId)
        && memberData(orgId).get('role','') == 'admin';
    }

    // Cashier: role == 'cashier' AND approved == true (single get)
    function isOrgCashier(orgId) {
      return memberExists(orgId)
        && memberData(orgId).get('role','') == 'cashier'
        && memberData(orgId).get('approved', false) == true;
    }

    // Any approved member (includes cashiers since they must also be approved)
    function isApprovedMember(orgId) {
      return memberExists(orgId)
        && memberData(orgId).get('approved', false) == true;
    }

    function isOwnDoc(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }


    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isOwnDoc(userId);
      allow update: if isOwnDoc(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }


    // ── Organizations ─────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
      allow create: if isSignedIn();
      // SuperAdmin: full rights on org doc.
      // OrgAdmin: can update settings and orgFeatures (feature activation layer)
      //           but NOT features (superadmin unlock layer), limits, or status.
      // Direct field equality is more reliable than affectedKeys() for nested writes.
      allow update:
        if isSuperAdmin()
        || (isOrgAdmin(orgId)
            && request.resource.data.get('features', {}) == resource.data.get('features', {})
            && request.resource.data.get('limits',   {}) == resource.data.get('limits',   {})
            && request.resource.data.get('status', null) == resource.data.get('status', null));
      allow delete: if isSuperAdmin();


      // ── Members ─────────────────────────────────────────────────────────
      match /members/{memberId} {
        allow read:
          if isSuperAdmin()
          || isOrgAdmin(orgId)
          || isOwnDoc(memberId)
          // Approved members can read the directory when org admin has activated it
          || (isApprovedMember(orgId)
              && get(/databases/$(database)/documents/organizations/$(orgId)).data
                  .get('orgFeatures',{}).get('memberDirectory', false) == true);

        allow create:
          if isSuperAdmin() || isOrgAdmin(orgId) || isOwnDoc(memberId);

        // Members may update their own profile including nominee fields
        // (nomineeNameEnglish, nomineenameBengali, nomineeNID, nomineeRelationship, nomineePhone)
        // but CANNOT touch role / approval / cashier assignments / committee role / entryFeePaid / idNo.
        allow update:
          if isSuperAdmin()
          || isOrgAdmin(orgId)
          || (isOwnDoc(memberId)
              && request.resource.data.get('role',            '') == resource.data.get('role',            '')
              && request.resource.data.get('approved',     false) == resource.data.get('approved',     false)
              && request.resource.data.get('cashierMethods',  []) == resource.data.get('cashierMethods',  [])
              && request.resource.data.get('cashierAccountIds',[]) == resource.data.get('cashierAccountIds',[])
              && request.resource.data.get('committeeRole',   '') == resource.data.get('committeeRole',   '')
              && request.resource.data.get('entryFeePaid', false) == resource.data.get('entryFeePaid', false)
              && request.resource.data.get('idNo',            '') == resource.data.get('idNo',            ''));

        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Investments (installment payments) ───────────────────────────────
      match /investments/{investmentId} {
        // All approved members (including cashiers) can read and create payments
        allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);

        // Cashier may ONLY flip status + set verifiedAt/verifiedBy — nothing else
        allow update:
          if isSuperAdmin()
          || isOrgAdmin(orgId)
          || (isOrgCashier(orgId)
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['status','verifiedAt','verifiedBy']));

        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Cashier Transfers ────────────────────────────────────────────────
      match /cashierTransfers/{transferId} {
        allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isOrgCashier(orgId);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId) || isOrgCashier(orgId);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId);
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Expenses ─────────────────────────────────────────────────────────
      // Separated from catch-all so cashiers can auto-create fee expenses
      match /expenses/{expenseId} {
        allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);

        // Cashier may only CREATE (auto fee expense from transfer); cannot edit or delete
        allow create: if isSuperAdmin() || isOrgAdmin(orgId) || isOrgCashier(orgId);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId);
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Notifications ────────────────────────────────────────────────────
      match /notifications/{notifId} {
        // Users can read/update/delete their own notifications
        allow read:
          if isSuperAdmin()
          || isOrgAdmin(orgId)
          || (isSignedIn() && resource.data.get('userId','') == request.auth.uid);

        allow update:
          if isSuperAdmin()
          || isOrgAdmin(orgId)
          || (isSignedIn() && resource.data.get('userId','') == request.auth.uid);

        allow delete:
          if isSuperAdmin()
          || isOrgAdmin(orgId)
          || (isSignedIn() && resource.data.get('userId','') == request.auth.uid);

        // Admin and cashier can create notifications (e.g. verify, transfer alerts)
        allow create:
          if isSuperAdmin() || isOrgAdmin(orgId) || isOrgCashier(orgId);
      }


      // ── File Library ──────────────────────────────────────────────────────
      match /files/{fileId} {
        allow read:  if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow write: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Entry Fees (F6) ──────────────────────────────────────────────────────
      // One-time non-refundable joining fees. Members read own record only.
      match /entryFees/{feeId} {
        allow read:
          if isSuperAdmin()
          || isOrgAdmin(orgId)
          || (isApprovedMember(orgId)
              && resource.data.get('userId','') == request.auth.uid);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId);
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Asset Registry (F17) ─────────────────────────────────────────────────
      // Org-owned assets. All approved members read; admin writes.
      match /assets/{assetId} {
        allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId);
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Investment Projects (F2) ──────────────────────────────────────────────
      // Tracks investment projects (Musharaka, Mudaraba, Ijara, etc.).
      // Separate from /investments which are installment payment records.
      // Investment Projects (F2)
      match /investmentProjects/{projectId} {
        allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId);
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);

        // Periodic return entries (rent, dividend, profit_share, etc.)
        match /returns/{returnId} {
          allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
          allow create: if isSuperAdmin() || isOrgAdmin(orgId);
          // update allowed for marking distributedInDistributionId after payout
          allow update: if isSuperAdmin() || isOrgAdmin(orgId);
          allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
        }

        // Project-level expenses (maintenance, tax, management fees, etc.)
        match /projectExpenses/{expenseId} {
          allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
          allow create: if isSuperAdmin() || isOrgAdmin(orgId);
          allow update: if isSuperAdmin() || isOrgAdmin(orgId);
          allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
        }
      }


      // ── Profit Distributions (F3) ─────────────────────────────────────────────
      // Annual profit declaration and per-member share records.
      match /profitDistributions/{distId} {
        allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId);
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Loans / Interest-Free (F1) ────────────────────────────────────────────
      // Members apply (create); only admin can approve/update. Members read own only.
      match /loans/{loanId} {
        allow read:
          if isSuperAdmin()
          || isOrgAdmin(orgId)
          || (isApprovedMember(orgId)
              && resource.data.get('userId','') == request.auth.uid);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId);
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Catch-all ─────────────────────────────────────────────────────────
      // Covers: income, penalties, investments (as a collection, handled above),
      // subscriptions, specialSubscriptions, distributions, reports, etc.
      // Note: expenses, cashierTransfers, notifications are matched ABOVE with
      // finer-grained rules and will NOT fall through to this catch-all.
      match /{collection}/{docId} {
        allow read:  if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow write: if isSuperAdmin() || isOrgAdmin(orgId);
      }

    } // end organizations/{orgId}


    // ── Invite Links ──────────────────────────────────────────────────────
    match /invites/{inviteId} {
      allow read:   if true;
      allow create:
        if isSuperAdmin()
        || (isSignedIn() && isOrgAdmin(request.resource.data.get('orgId','')));
      allow delete:
        if isSuperAdmin()
        || (isSignedIn() && isOrgAdmin(resource.data.get('orgId','')));
      allow update: if false;
    }


    // ── Platform settings ─────────────────────────────────────────────────
    match /platform/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();
    }

  }
}
